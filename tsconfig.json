{
    "compilerOptions": {
        "module": "nodenext",
        "target": "es2015",
        "moduleResolution": "nodenext",
        "noImplicitAny": true,
        "sourceMap": true,
        "declaration": true,
        "outDir": "dist/",
        "rootDir": "src/",
        "lib": ["es2015"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}